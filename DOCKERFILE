FROM node:20-alpine

# Instalar Chromium y dependencias necesarias
RUN apk add --no-cache \
    chromium \
    nss \
    freetype \
    harfbuzz \
    ca-certificates \
    ttf-freefont \
    && rm -rf /var/cache/apk/*

WORKDIR /app

# Crear directorio para sesiones
RUN mkdir -p /app/instances

# Copiar y instalar dependencias
COPY package*.json ./
RUN npm install --production

# Copiar código fuente
COPY server.js .

# Configurar Puppeteer para usar Chromium del sistema
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true
ENV PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Puerto que Railway espera
EXPOSE 8080

# Verificar que Chromium existe (debug)
RUN test -f /usr/bin/chromium-browser && echo "✅ Chromium encontrado" || echo "❌ Chromium NO encontrado"

CMD ["node", "server.js"]