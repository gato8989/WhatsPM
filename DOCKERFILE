FROM node:20-bookworm-slim

# Instalar Chromium
RUN apt-get update && apt-get install -y \
    chromium \
    ca-certificates \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libglib2.0-0 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libx11-xcb1 \
    libxcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libxss1 \
    libxtst6 \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Crear directorio para sesiones
RUN mkdir -p /app/instances

# Crear script de override para puppeteer
RUN mkdir -p /usr/local/lib/node_modules/puppeteer && \
    echo "module.exports = { launch: () => { throw new Error('Override') } }" > /usr/local/lib/node_modules/puppeteer/index.js

# Copiar package.json e instalar
COPY package*.json ./
RUN npm install --production

# SOBREESCRIBIR el puppeteer instalado con un wrapper que use Chromium del sistema
RUN node -e "const fs = require('fs'); const path = require('path'); \
    const puppeteerPath = path.dirname(require.resolve('puppeteer')); \
    const wrapper = ` \
const chromiumPath = '/usr/bin/chromium';\
const puppeteer = require('puppeteer-core');\
module.exports = puppeteer;\
module.exports.launch = (opts = {}) => {\
    opts.executablePath = chromiumPath;\
    opts.args = [...(opts.args || []), '--no-sandbox', '--disable-setuid-sandbox'];\
    return puppeteer.launch(opts);\
};\
`; \
    fs.writeFileSync(path.join(puppeteerPath, 'index.js'), wrapper);"

# Copiar código fuente
COPY server.js .

# Verificar Chromium
RUN test -f /usr/bin/chromium && echo "✅ Chromium listo"

EXPOSE 8080

CMD ["node", "server.js"]