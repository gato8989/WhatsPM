FROM node:18-slim

# Instalar dependencias del sistema para Puppeteer
RUN apt-get update && apt-get install -y \
    ca-certificates \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libglib2.0-0 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libx11-xcb1 \
    libxcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libxss1 \
    libxtst6 \
    xdg-utils \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Crear directorio para sesiones
RUN mkdir -p /app/instances

# Copiar archivos de Node
COPY package*.json ./
RUN npm install

# Instalar puppeteer explícitamente (esto descargará Chrome automáticamente)
RUN npm install puppeteer --save

# Copiar código fuente
COPY server.js .

# Configurar Puppeteer para usar Chrome descargado
ENV PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=false

EXPOSE 8080

CMD ["node", "server.js"]